{
  "slug": "whoami",
  "name": "Whoami",
  "category": "devtools",
  "icon": "whoami",
  "description": "A tiny HTTP server that echoes request information. Useful for testing deployments.",
  "tags": ["devtools", "testing", "utilities"],
  "versions": ["latest"],
  "default_version": "latest",
  "docs_url": "https://github.com/traefik/whoami",
  "min_tidefly": "0.1.0",
  "official": true,
  "fields": [
    {
      "key": "service_name",
      "label": "Service Name",
      "type": "string",
      "placeholder": "whoami",
      "required": true,
      "generated": false
    },
    {
      "key": "domain",
      "label": "Domain",
      "type": "string",
      "placeholder": "whoami.example.com",
      "required": false,
      "generated": false
    }
  ],
  "manifest": {
    "apiVersion": "tidefly/v1",
    "kind": "service",
    "metadata": {
      "name": "{service_name}",
      "labels": {
        "tidefly.template": "whoami",
        "tidefly.source": "template"
      }
    },
    "spec": {
      "container": {
        "image": "traefik/whoami:latest"
      },
      "expose": {
        "port": 80,
        "domain": "{domain}",
        "tls": true
      },
      "health": {
        "test": ["CMD", "/whoami", "--help"],
        "interval": "10s",
        "timeout": "3s",
        "retries": 3,
        "startPeriod": "5s"
      },
      "scaling": {
        "replicas": 1,
        "restart": "always",
        "strategy": "blue-green"
      }
    }
  }
}