{
  "slug": "postgres",
  "name": "PostgreSQL",
  "category": "database",
  "icon": "postgres",
  "description": "A powerful, open source object-relational database system.",
  "versions": ["17", "18", "16", "15"],
  "default_version": "17",
  "fields": [
    {
      "key": "service_name",
      "label": "Service Name",
      "type": "string",
      "placeholder": "my-postgres",
      "required": true,
      "generated": false
    },
    {
      "key": "db_name",
      "label": "Database Name",
      "type": "string",
      "default": "app",
      "required": true,
      "generated": false
    },
    {
      "key": "password",
      "label": "Postgres Password",
      "type": "credential",
      "required": true,
      "generated": true,
      "store_hash": true,
      "show_plaintext_once": true
    },
    {
      "key": "expose",
      "label": "Expose externally via TLS",
      "type": "boolean",
      "default": false,
      "required": false
    },
    {
      "key": "external_port",
      "label": "External Port",
      "type": "port",
      "required": false,
      "depends_on": "expose"
    }
  ],
  "manifest": {
    "apiVersion": "tidefly/v1",
    "kind": "service",
    "metadata": {
      "name": "{service_name}",
      "labels": {
        "tidefly.template": "postgres",
        "tidefly.source": "template"
      }
    },
    "spec": {
      "container": {
        "image": "postgres:{version}",
        "env": [
          { "name": "POSTGRES_PASSWORD", "value": "{password}" },
          { "name": "POSTGRES_DB", "value": "{db_name}" },
          { "name": "PGDATA", "value": "/var/lib/postgresql/data/pgdata" }
        ],
        "volumes": [
          { "name": "{service_name}_data", "mountPath": "/var/lib/postgresql/data" }
        ]
      },
      "health": {
        "test": ["CMD-SHELL", "pg_isready -U postgres -d {db_name}"],
        "interval": "5s",
        "timeout": "3s",
        "retries": 10,
        "startPeriod": "30s"
      },
      "scaling": {
        "replicas": 1,
        "restart": "always",
        "strategy": "rolling"
      }
    }
  }
}