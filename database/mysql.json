{
  "slug": "mysql",
  "name": "MySQL",
  "category": "database",
  "icon": "mysql",
  "description": "The world's most popular open source relational database.",
  "versions": ["9.7", "8.4.0"],
  "default_version": "9.7",
  "fields": [
    {
      "key": "service_name",
      "label": "Service Name",
      "type": "string",
      "placeholder": "my-mysql",
      "required": true,
      "generated": false
    },
    {
      "key": "db_name",
      "label": "Database Name",
      "type": "string",
      "placeholder": "mydb",
      "required": true,
      "generated": false
    },
    {
      "key": "db_user",
      "label": "Database User",
      "type": "string",
      "placeholder": "myuser",
      "required": true,
      "generated": false
    },
    {
      "key": "db_password",
      "label": "Password",
      "type": "credential",
      "required": true,
      "generated": true,
      "store_hash": true,
      "show_plaintext_once": true
    },
    {
      "key": "root_password",
      "label": "Root Password",
      "type": "credential",
      "required": true,
      "generated": true,
      "store_hash": true,
      "show_plaintext_once": true
    },
    {
      "key": "expose",
      "label": "Expose externally via TLS",
      "type": "boolean",
      "default": false,
      "required": false
    },
    {
      "key": "external_port",
      "label": "External Port",
      "type": "port",
      "required": false,
      "depends_on": "expose"
    }
  ],
  "manifest": {
    "apiVersion": "tidefly/v1",
    "kind": "service",
    "metadata": {
      "name": "{service_name}",
      "labels": {
        "tidefly.template": "mysql",
        "tidefly.source": "template"
      }
    },
    "spec": {
      "container": {
        "image": "mysql:{version}",
        "env": [
          { "name": "MYSQL_ROOT_PASSWORD", "value": "{root_password}" },
          { "name": "MYSQL_DATABASE", "value": "{db_name}" },
          { "name": "MYSQL_USER", "value": "{db_user}" },
          { "name": "MYSQL_PASSWORD", "value": "{db_password}" }
        ],
        "volumes": [
          { "name": "{service_name}_data", "mountPath": "/var/lib/mysql" }
        ]
      },
      "health": {
        "test": ["CMD", "mysqladmin", "ping", "-h", "localhost"],
        "interval": "5s",
        "timeout": "5s",
        "retries": 10,
        "startPeriod": "30s"
      },
      "scaling": {
        "replicas": 1,
        "restart": "always",
        "strategy": "rolling"
      }
    }
  }
}