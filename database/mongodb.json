{
  "slug": "mongodb",
  "name": "MongoDB",
  "category": "database",
  "icon": "mongodb",
  "description": "A document-oriented NoSQL database for modern applications.",
  "versions": ["8.0", "8.2"],
  "default_version": "8.0",
  "fields": [
    {
      "key": "service_name",
      "label": "Service Name",
      "type": "string",
      "placeholder": "my-mongodb",
      "required": true,
      "generated": false
    },
    {
      "key": "db_name",
      "label": "Database Name",
      "type": "string",
      "placeholder": "mydb",
      "required": true,
      "generated": false
    },
    {
      "key": "db_user",
      "label": "Root Username",
      "type": "string",
      "placeholder": "admin",
      "required": true,
      "generated": false
    },
    {
      "key": "db_password",
      "label": "Root Password",
      "type": "credential",
      "required": true,
      "generated": true,
      "store_hash": true,
      "show_plaintext_once": true
    },
    {
      "key": "expose",
      "label": "Expose externally via TLS",
      "type": "boolean",
      "default": false,
      "required": false
    },
    {
      "key": "external_port",
      "label": "External Port",
      "type": "port",
      "required": false,
      "depends_on": "expose"
    }
  ],
  "manifest": {
    "apiVersion": "tidefly/v1",
    "kind": "service",
    "metadata": {
      "name": "{service_name}",
      "labels": {
        "tidefly.template": "mongodb",
        "tidefly.source": "template"
      }
    },
    "spec": {
      "container": {
        "image": "mongo:{version}",
        "env": [
          { "name": "MONGO_INITDB_ROOT_USERNAME", "value": "{db_user}" },
          { "name": "MONGO_INITDB_ROOT_PASSWORD", "value": "{db_password}" },
          { "name": "MONGO_INITDB_DATABASE", "value": "{db_name}" }
        ],
        "volumes": [
          { "name": "{service_name}_data", "mountPath": "/data/db" },
          { "name": "{service_name}_config", "mountPath": "/data/configdb" }
        ]
      },
      "health": {
        "test": ["CMD", "mongosh", "--eval", "db.adminCommand('ping')"],
        "interval": "10s",
        "timeout": "5s",
        "retries": 10,
        "startPeriod": "30s"
      },
      "scaling": {
        "replicas": 1,
        "restart": "always",
        "strategy": "rolling"
      }
    }
  }
}